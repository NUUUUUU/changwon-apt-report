# 창원 아파트 리포트 — API 키 템플릿
# 사용법: 이 파일을 복사해 ".env" 로 만들고 값을 채웁니다. (.env 는 git에 올라가지 않음)

# ── 1) 국토교통부 실거래가 (공공데이터포털 data.go.kr) ──  [필수]
# 하나의 '일반 인증키'로 매매·전월세·REB 등 신청한 모든 API에 공용으로 쓰입니다.
MOLIT_SERVICE_KEY=

# ── 2) 카카오 디벨로퍼스 (developers.kakao.com) ──  [필수]
KAKAO_REST_KEY=          # 통근시간(모빌리티)·지오코딩(로컬)
KAKAO_JS_KEY=            # 리포트 지도 임베드(JavaScript 키)
# '나에게 보내기'는 이후 OAuth로 토큰 발급 (지금은 비워둠)
KAKAO_REFRESH_TOKEN=

# ── 3) 한국부동산원 REB OpenAPI ──  [권장]
REB_SERVICE_KEY=

# ── 4) NEIS 학교 OpenAPI (open.neis.go.kr) ──  [선택]
NEIS_API_KEY=
