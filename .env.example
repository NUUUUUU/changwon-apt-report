# 창원 아파트 리포트 — API 키 템플릿
# 사용법: 이 파일을 복사해 ".env" 로 만들고 값을 채웁니다. (.env 는 git에 올라가지 않음)
# (주석은 줄을 분리해 두었습니다 — source 해도 안전)

# 1) 국토교통부 실거래가 (data.go.kr) — 필수
MOLIT_SERVICE_KEY=

# 2) 카카오 디벨로퍼스 (developers.kakao.com)
# REST 키 — 통근(모빌리티)·지오코딩(로컬)·육아/상권 (필수)
KAKAO_REST_KEY=
# JavaScript 키 — 리포트 지도 임베드 (필수)
KAKAO_JS_KEY=
# 카톡 '나에게 보내기' OAuth (talk_message scope) — 발송용
KAKAO_REFRESH_TOKEN=
KAKAO_CLIENT_SECRET=

# 3) 네이버 검색 API (developers.naver.com) — 실거주 후기 (선택)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# 4) (선택) 한국부동산원 REB / NEIS 학교
REB_SERVICE_KEY=
NEIS_API_KEY=
